generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique(map: "username")
  password            String
  name                String
  school              String?
  grade               String?
  className           String?
  age                 Int?
  signature           String?
  phone               String               @db.VarChar(20)
  role                Role                 @default(STUDENT)
  avatar              String?
  balance             Float                @default(0)
  isDisabled          Boolean              @default(false)
  createdAt           DateTime             @default(now()) @db.Timestamp(0)
  updatedAt           DateTime             @updatedAt @db.Timestamp(0)
  Achievement         Achievement[]
  Activity            Activity[]
  BalanceTransaction  BalanceTransaction[]
  createdBases        Base[]               @relation("CreatedBases")
  BaseCoupon          BaseCoupon[]
  Carousel            Carousel[]
  Certificate         Certificate[]
  Favorite            Favorite[]
  GiftCard            GiftCard[]
  Notification        Notification[]
  Order               Order[]
  Policy              Policy[]
  Service             Service[]
  UserActivity        UserActivity[]
  UserHistory_User    UserHistory[]        @relation("UserHistory_userIdToUser")
  UserHistory_changed UserHistory[]        @relation("UserHistory_changedByToUser")
  userActivityScores  UserActivityScore[]
  awardRecords        AwardRecord[]        @relation("AwardRecordUser")
  issuedAwards        AwardRecord[]        @relation("AwardRecordIssuer")
  adminOfBases        Base[]               @relation("BaseAdmins")
  contactsA           Contact[]            @relation("ContactUserA")
  contactsB           Contact[]            @relation("ContactUserB")
  sentFriendRequests  FriendRequest[]      @relation("FriendRequestFrom")
  receivedFriendRequests FriendRequest[]   @relation("FriendRequestTo")
  sentMessages        ChatMessage[]        @relation("ChatFromUser")
  receivedMessages    ChatMessage[]        @relation("ChatToUser")

  @@map("users")
}

model Base {
  id           Int        @id @default(autoincrement())
  name         String
  type         String
  address      String
  contact      String?
  description  String?    @db.Text
  isActive     Boolean    @default(true)
  isApproved   Boolean    @default(false)
  rejectReason String?
  createdAt    DateTime   @default(now()) @db.Timestamp(0)
  updatedAt    DateTime   @updatedAt @db.Timestamp(0)
  createdBy    Int?
  activities   Activity[] @relation("ActivityToBase")
  baseCoupons  BaseCoupon[] @relation("BaseCouponToBase")
  User_creator User?      @relation("CreatedBases", fields: [createdBy], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "bases_ibfk_1")
  admins       User[]     @relation("BaseAdmins")

  @@index([createdBy], map: "bases_ibfk_1")
  @@map("bases")
}

model UserHistory {
  id         Int      @id @default(autoincrement())
  userId     Int
  changedBy  Int?
  username   String
  name       String
  phone      String
  school     String?
  grade      String?
  className  String?
  role       String
  isDisabled Boolean
  createdAt  DateTime @default(now())

  user       User @relation("UserHistory_userIdToUser", fields: [userId], references: [id])
  changedByUser User? @relation("UserHistory_changedByToUser", fields: [changedBy], references: [id])

  @@map("user_histories")
}

model Certificate {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  issuer      String?
  issueDate   DateTime?
  fileUrl     String?
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Carousel {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy Int

  creator User @relation(fields: [createdBy], references: [id])

  @@map("carousels")
}

model Policy {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  tags        String?
  videoUrl    String?
  fileUrl     String?
  isDraft     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Int

  creator User @relation(fields: [createdBy], references: [id])

  @@map("policies")
}

model Achievement {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  tags        String?
  videoUrl    String?
  fileUrl     String?
  isDraft     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   Int

  creator User @relation(fields: [createdBy], references: [id])

  @@map("achievements")
}

model Activity {
  id          Int           @id @default(autoincrement())
  name        String
  type        String
  description String?       @db.Text
  time        DateTime
  location    String
  maxPeople   Int?
  price       Float?
  isActive    Boolean       @default(true)
  isApproved  Boolean       @default(false)
  rejectReason String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  baseId      Int
  createdBy   Int?

  base     Base           @relation("ActivityToBase", fields: [baseId], references: [id], onDelete: Cascade)
  users    UserActivity[]
  orders   Order[]
  creator  User?          @relation(fields: [createdBy], references: [id])
  awards   ActivityAward[]
  scores   UserActivityScore[]
  awardRecords AwardRecord[]

  @@map("activities")
}

model UserActivity {
  id         Int      @id @default(autoincrement())
  userId     Int
  activityId Int
  status     ActivityStatus @default(REGISTERED)
  adminNote  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@map("user_activities")
}

model Service {
  id              Int      @id @default(autoincrement())
  title           String
  description     String   @db.Text
  tags            String?
  coverImage      String?
  price           Float?
  maxPeople       Int?
  endTime         DateTime?
  videoUrl        String?
  fileUrl         String?
  isActive        Boolean  @default(true)
  isHot           Boolean  @default(false)
  sortOrder       Int      @default(0)
  eventType       ServiceEventType @default(SPECIAL_SERVICE)
  location        String?
  registerDeadline DateTime?
  eventRules      String?  @db.Text
  eventResults    String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       Int

  creator User    @relation(fields: [createdBy], references: [id])
  orders  Order[]

  @@map("services")
}

model Order {
  id             Int           @id @default(autoincrement())
  orderNo        String        @unique
  userId         Int
  serviceId      Int?
  activityId     Int?
  amount         Float
  originalAmount Float?
  discountAmount Float        @default(0)
  couponCode     String?      @db.VarChar(16)
  baseCouponId   Int?
  status         OrderStatus   @default(PENDING)
  paymentMethod  String?
  userNote       String?
  adminNote      String?
  isRefunded     Boolean       @default(false)
  refundedAmount Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user     User       @relation(fields: [userId], references: [id])
  service  Service?   @relation(fields: [serviceId], references: [id])
  activity Activity? @relation(fields: [activityId], references: [id])
  baseCoupon BaseCoupon? @relation(fields: [baseCouponId], references: [id])
  refunds  Refund[]
  balanceTransactions BalanceTransaction[]

  @@map("orders")
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  targetType String
  targetId   Int
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, targetId])
  @@map("favorites")
}

enum Role {
  SUPER_ADMIN
  ACTIVITY_ADMIN
  STUDENT
}

enum ActivityStatus {
  REGISTERED
  APPROVED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDING
  REFUNDED
}

model Contact {
  id         Int      @id @default(autoincrement())
  userA      Int
  userB      Int
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user1      User     @relation("ContactUserA", fields: [userA], references: [id], onDelete: Cascade)
  user2      User     @relation("ContactUserB", fields: [userB], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@unique([userA, userB])
  @@map("contacts")
}

model FriendRequest {
  id         Int      @id @default(autoincrement())
  fromId     Int
  toId       Int
  message    String?  @db.Text
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  fromUser   User     @relation("FriendRequestFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toUser     User     @relation("FriendRequestTo", fields: [toId], references: [id], onDelete: Cascade)

  @@index([toId], map: "friend_requests_toId_idx")
  @@index([fromId], map: "friend_requests_fromId_idx")
  @@map("friend_requests")
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  contactId  Int
  fromId     Int
  toId       Int
  content    String   @db.Text
  createdAt  DateTime @default(now())

  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  fromUser   User     @relation("ChatFromUser", fields: [fromId], references: [id], onDelete: Cascade)
  toUser     User     @relation("ChatToUser", fields: [toId], references: [id], onDelete: Cascade)

  @@index([contactId], map: "chat_messages_contactId_idx")
  @@map("chat_messages")
}

enum ServiceEventType {
  COMPETITION
  STUDY_TOUR
  SOCIAL_PRACTICE
  PUBLIC_WELFARE
  SPECIAL_SERVICE
}

model Notification {
  id          Int      @id @default(autoincrement())
  title       String
  content     String   @db.Text
  type        NotificationType @default(INFO)
  targetRole  Role?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  Int

  creator User @relation(fields: [createdBy], references: [id])

  @@map("notifications")
}

model BalanceTransaction {
  id          Int                 @id @default(autoincrement())
  userId      Int
  type        BalanceTransactionType
  amount      Float
  balance     Float
  description String?
  orderId     Int?
  createdAt   DateTime            @default(now())

  user  User   @relation(fields: [userId], references: [id])
  order Order? @relation(fields: [orderId], references: [id])

  @@map("balance_transactions")
}

model Refund {
  id           Int       @id @default(autoincrement())
  orderId      Int
  amount       Float
  reason       String?
  status       String    @default("PENDING")
  processedBy  Int?
  processedAt  DateTime?
  decisionNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@map("refunds")
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
  ANNOUNCEMENT
}

enum BalanceTransactionType {
  RECHARGE
  PAYMENT
  REFUND
  REWARD
  GIFT_CARD
}

enum AwardRuleType {
  SCORE_RANGE
  RANK_RANGE
}

enum AwardType {
  AUTOMATIC
  MANUAL
}

model GiftCard {
  id          Int      @id @default(autoincrement())
  cardCode    String   @unique @db.VarChar(16)
  amount      Float
  totalUses   Int      @default(1)
  usedCount   Int      @default(0)
  isUsed      Boolean  @default(false)
  isActive    Boolean  @default(true)
  usedBy      Int?
  usedAt      DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [usedBy], references: [id])

  @@map("gift_cards")
}

model BaseCoupon {
  id          Int      @id @default(autoincrement())
  couponCode  String   @db.VarChar(16)
  amount      Float
  baseId      Int
  usageLimit  Int      @default(1)
  usedCount   Int      @default(0)
  isUsed      Boolean  @default(false)
  usedBy      Int?
  usedAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  base Base  @relation("BaseCouponToBase", fields: [baseId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [usedBy], references: [id])
  orders Order[]

  @@unique([baseId, couponCode])
  @@map("base_coupons")
}

model ActivityAward {
  id          Int      @id @default(autoincrement())
  activityId  Int
  name        String
  description String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  rules    AwardRule[]
  records  AwardRecord[]

  @@map("activity_awards")
}

model AwardRule {
  id          Int          @id @default(autoincrement())
  awardId     Int
  ruleType    AwardRuleType
  minScore    Int?
  maxScore    Int?
  minRank     Int?
  maxRank     Int?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  award ActivityAward @relation(fields: [awardId], references: [id], onDelete: Cascade)

  @@map("award_rules")
}

model UserActivityScore {
  id          Int      @id @default(autoincrement())
  userId      Int
  activityId  Int
  score       Int      @default(0)
  rank        Int?
  isFinal     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([userId, activityId])
  @@map("user_activity_scores")
}

model AwardRecord {
  id          Int          @id @default(autoincrement())
  userId      Int
  activityId  Int
  awardId     Int
  awardType   AwardType    @default(AUTOMATIC)
  issuedBy    Int?
  issuedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())

  user     User          @relation("AwardRecordUser", fields: [userId], references: [id], onDelete: Cascade)
  activity Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  award    ActivityAward @relation(fields: [awardId], references: [id], onDelete: Cascade)
  issuer   User?         @relation("AwardRecordIssuer", fields: [issuedBy], references: [id])

  @@unique([userId, activityId, awardId])
  @@map("award_records")
}
